{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "texthelpermd",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "reddit": {
      "asUser": [
        "SUBMIT_POST"
      ]
    },
    "media": true
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "u/texthelpermd",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "texthelpermd_dev"
  }
}