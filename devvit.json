{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "texthelpermd",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "reddit": {
      "asUser": [
        "SUBMIT_POST",
        "SUBMIT_COMMENT"
      ]
    },
    "media": true
  },
  "forms": {
    "commentText": "/internal/forms/commentText",
    "postText": "/internal/forms/postText"
  },
  "menu": {
    "items": [
      {
        "label": "Create a interface Post",
        "description": "u/texthelpermd (for mods)",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Create a new Post()",
        "description": "u/texthelpermd (for user)",
        "location": "subreddit",
        "forUserType": "user",
        "endpoint": "/internal/menu/post"
      },
      {
        "label": "Reply-To: this",
        "description": "u/texthelpermd",
        "location": [
          "comment",
          "post"
        ],
        "forUserType": "user",
        "endpoint": "/internal/menu/start-workflow"
      }
    ]
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "texthelpermd_dev"
  }
}